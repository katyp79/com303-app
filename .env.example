# 1. Copy this file and rename the copy to ".env"  (just ".env", no .example)
# 2. Paste your Anthropic API key after the = sign below (no quotes, no spaces)
# 3. Save. Never share this file or commit it anywhere public.

ANTHROPIC_API_KEY=

# Optional: which Claude model runs the conversation.
# claude-sonnet-4-6  = great quality, low cost (recommended default)
# claude-haiku-4-5-20251001 = cheapest + fastest, slightly simpler questions
MODEL=claude-sonnet-4-6

# Optional: the port the app runs on (default 3000)
PORT=3000

# Optional: a simple password you'll type to open the Instructor side.
# Students never need this. Leave blank to disable the gate while piloting.
INSTRUCTOR_PASSWORD=
